		</actuator>
		
		<switch name="/systems/fuel/trans-aux-upper-l-cmd">
			<default value="0"/>
			<test value="1">
				/controls/fuel/trans-aux-l ge 1
			</test>
		</switch>
		
		<switch name="/systems/fuel/trans-aux-upper-l">
			<default value="0"/>
			<test logic="AND" value="1"> <!-- Power source is guess, unknown -->
				/systems/electrical/bus/ac-1 ge 112
				/systems/fuel/trans-aux-upper-l-cmd eq 1
