				/controls/fuel/trans-aux-l eq 1
			</test>
		</switch>
		
		<switch name="/systems/fuel/trans-aux-lower-l">
			<default value="0"/>
			<test logic="AND" value="1"> <!-- Power source is guess, unknown -->
				/systems/electrical/bus/ac-2 ge 112
				/systems/fuel/trans-aux-lower-l-cmd eq 1
				/systems/failures/fuel/trans-aux-lower-l ne 1
			</test>
