<system name="DC-10: Fuel">
	
	<property value="0">/systems/apu/dc-fuel-pump</property>
	
	<channel name="Main Fuel Logic" execrate="8">
		
		<!-- Pressure Level -->
		<fcs_function name="/systems/fuel/tank-pump-pressure[0]">
			<function>
				<table>
					<independentVar lookup="row">propulsion/tank[0]/contents-lbs</independentVar>
					<tableData>
						 10   0
						130  20
					</tableData>
				</table>
			</function>
		</fcs_function>

		<fcs_function name="/systems/fuel/tank-pump-pressure[1]">
			<function>
				<table>
					<independentVar lookup="row">propulsion/tank[1]/contents-lbs</independentVar>
